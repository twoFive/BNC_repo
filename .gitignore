# Pliki Excel - binarne, nie do Git (z wyjątkami niżej)
*.xlsm
*.xlsx
*.xls

# Tymczasowe pliki Office
~$*

# Foldery z plikami binarnymi
Releases/
CacheFolder/

# Wyjątek: chcemy commitować .frx mimo że są binarne (są częścią eksportu UserForm)
!Source/Forms/*.frx

# Wyjątek: Working/ jest trackowane jako snapshot xlsm + ZIP archiwalny
# (świadomy wyjątek dla milestone snapshots; pełna historia ma być w Source/)
!Working/
!Working/*.xlsm
!Working/*.zip

# OS / IDE
Thumbs.db
.DS_Store
.vscode/
.idea/

# Claude Code session data
.claude/

# Lokalny notatnik decyzji projektowych (tylko dla autora, nie commitowany)
Notatki/NOTES.md
